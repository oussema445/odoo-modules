<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Action qui génère le PDF -->
    <record id="action_report_book" model="ir.actions.report">
        <field name="name">Library Books Report</field>
        <field name="model">library.book</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">my_library.report_book_template</field>
        <field name="report_file">my_library.report_book_template</field>
        <field name="binding_model_id" ref="model_library_book"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Template QWeb -->
    <template id="report_book_template">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <h2>Library Books Report</h2>
                    <table class="table table-bordered table-sm">
                        <thead>
                            <tr>
                                <th>Title</th>
                                <th>Author</th>
                                <th>ISBN</th>
                                <th>Published</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="book">
                                <tr>
                                    <td><t t-esc="book.name"/></td>
                                    <td><t t-esc="book.author_id.name or ''"/></td>
                                    <td><t t-esc="book.isbn or ''"/></td>
                                    <td><t t-esc="book.date_published or ''"/></td>
                                    <td><t t-esc="book.state"/></td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </t>
        </t>
    </template>

</odoo>
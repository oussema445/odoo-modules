<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="hr_employee_custom_tree" model="ir.ui.view">
        <field name="name">hr.employee.custom.tree</field>
        <field name="model">hr.employee.custom</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="department_id"/>
                <field name="email"/>
                <field name="phone"/>
                <field name="active"/>
                <field name="hire_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="hr_employee_custom_form" model="ir.ui.view">
        <field name="name">hr.employee.custom.form</field>
        <field name="model">hr.employee.custom</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_resign"
                            string="Resign"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'active'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="department_id"/>
                        <field name="email"/>
                        <field name="phone"/>
                        <field name="hire_date"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Actions -->
    <record id="action_hr_employee_custom" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">hr.employee.custom</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="action_hr_department_custom" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr.department.custom</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_hr_custom_root"
              name="HR Custom"
              sequence="10"/>

    <menuitem id="menu_hr_employees"
              name="Employees"
              parent="menu_hr_custom_root"
              action="action_hr_employee_custom"/>

    <menuitem id="menu_hr_departments"
              name="Departments"
              parent="menu_hr_custom_root"
              action="action_hr_department_custom"/>

</odoo>
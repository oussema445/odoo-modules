<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Tree View -->
    <record id="hr_department_custom_tree" model="ir.ui.view">
        <field name="name">hr.department.custom.tree</field>
        <field name="model">hr.department.custom</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="manager_id"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="hr_department_custom_form" model="ir.ui.view">
        <field name="name">hr.department.custom.form</field>
        <field name="model">hr.department.custom</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="manager_id"/>
                    </group>
                    <notebook>
                        <page string="Employees">
                            <field name="employee_ids">
                                <tree>
                                    <field name="name"/>
                                    <field name="email"/>
                                    <field name="state"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

</odoo>